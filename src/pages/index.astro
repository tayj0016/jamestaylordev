---
import Base from '../layouts/Base.astro';
import '../styles/global.css';
---
<Base>
    <!-- NAV -->
    <nav class="fixed top-0 w-full z-50 px-6 py-4 flex justify-between items-center border-b border-neutral-800 bg-neutral-950/80 backdrop-blur-sm">
        <span class="font-semibold tracking-tight text-white">James W. Taylor</span>
        <div class="flex gap-6 text-sm text-neutral-400">
            <a href="#about" class="hover:text-white transition-colors">About</a>
            <a href="#services" class="hover:text-white transition-colors">Services</a>
            <a href="#tools" class="hover:text-white transition-colors">Tools</a>
            <a href="#projects" class="hover:text-white transition-colors">Projects</a>
            <a href="#contact" class="hover:text-white transition-colors">Contact</a>
        </div>
    </nav>

    <!-- HERO -->
    <section class="relative min-h-screen flex flex-col justify-center px-6 overflow-hidden">
        <div class="absolute inset-0 -z-10"
             style="background-image: radial-gradient(circle, rgba(255,255,255,0.06) 1px, transparent 1px); background-size: 28px 28px;"></div>
        <div class="absolute -z-10 sunset-orb"
             style="width: 800px; height: 800px; border-radius: 50%; background: radial-gradient(circle at center, rgba(180,60,255,0.20) 0%, rgba(220,90,40,0.16) 40%, rgba(30,20,80,0.08) 70%, transparent 100%); top: -150px; right: -250px; filter: blur(50px);"></div>
        <div class="absolute -z-10 sunset-orb-2"
             style="width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle at center, rgba(30,60,200,0.18) 0%, rgba(120,30,180,0.12) 50%, transparent 100%); bottom: -100px; left: -150px; filter: blur(60px);"></div>
        <div class="absolute -z-10 sunset-orb-3"
             style="width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle at center, rgba(200,60,20,0.12) 0%, rgba(160,30,120,0.10) 50%, transparent 100%); bottom: -50px; right: -100px; filter: blur(55px);"></div>
        <div class="max-w-4xl mx-auto w-full">
            <p class="text-neutral-500 text-sm mb-4 tracking-widest uppercase">Available for work</p>
            <h1 class="text-5xl md:text-7xl font-bold tracking-tight leading-tight mb-6">
                I build <span class="sunset-text">websites</span><br/>& <span class="sunrise-text">web apps.</span>
            </h1>
            <p class="text-neutral-400 text-lg md:text-xl max-w-xl mb-10">
                Freelance developer based in Jacksonville, FL. I handle development, deployment, and maintenance — start
                to finish.
            </p>
            <div class="flex gap-4">
                <a href="#projects"
                   class="px-6 py-3 bg-white text-neutral-950 font-medium rounded-lg hover:bg-neutral-200 transition-colors text-sm">View
                    my work</a>
                <a href="#contact"
                   class="px-6 py-3 border border-neutral-700 text-neutral-300 font-medium rounded-lg hover:border-neutral-500 hover:text-white transition-colors text-sm">Get
                    in touch</a>
            </div>
        </div>
    </section>

    <style>
        .sunset-text {
            background: linear-gradient(90deg, #a855f7, #f97316);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .sunrise-text {
            background: linear-gradient(90deg, #f97316, #ec4899, #a855f7);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .sunset-orb {
            animation: drift 12s ease-in-out infinite alternate;
        }

        .sunset-orb-2 {
            animation: drift 16s ease-in-out infinite alternate-reverse;
        }

        .sunset-orb-3 {
            animation: drift 20s ease-in-out infinite alternate;
        }

        @keyframes drift {
            0% {
                transform: translate(0px, 0px) scale(1);
            }
            50% {
                transform: translate(30px, 20px) scale(1.05);
            }
            100% {
                transform: translate(-20px, 30px) scale(0.97);
            }
        }
    </style>

    <!-- ABOUT -->
    <section id="about" class="py-24 px-6 max-w-4xl mx-auto">
        <p class="text-neutral-500 text-sm tracking-widest uppercase mb-4">About</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">A developer who cares about the details.</h2>
        <p class="text-neutral-400 text-lg leading-relaxed max-w-2xl mb-8">
            I'm a full-stack web and app developer with a focus on clean, performant, and maintainable code. I work with
            small businesses, startups, and individuals to bring their ideas to life — from a simple marketing site to a
            fully custom web application.
        </p>
        <div class="flex gap-4">
            <a href="https://github.com/tayj0016" target="_blank" rel="noopener noreferrer"
               class="flex items-center gap-2 px-4 py-2 border border-neutral-700 text-neutral-400 rounded-lg hover:border-neutral-500 hover:text-white transition-colors text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                </svg>
                GitHub
            </a>
            <a href="https://www.linkedin.com/in/james-w-taylor/" target="_blank" rel="noopener noreferrer"
               class="flex items-center gap-2 px-4 py-2 border border-neutral-700 text-neutral-400 rounded-lg hover:border-neutral-500 hover:text-white transition-colors text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                LinkedIn
            </a>
        </div>
    </section>

    <!-- SERVICES -->
    <section id="services" class="py-24 px-6 max-w-4xl mx-auto border-t border-neutral-800">
        <p class="text-neutral-500 text-sm tracking-widest uppercase mb-4">Services</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-12">What I do.</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {[
                {
                    title: "Web Development",
                    desc: "Custom websites built with modern frameworks — fast, responsive, and tailored to your brand and goals.",
                    accent: "#a855f7",
                    icon: "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"
                },
                {
                    title: "WordPress Development",
                    desc: "Custom WordPress sites with hand-built plugins to extend functionality well beyond off-the-shelf solutions.",
                    accent: "#818cf8",
                    icon: "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zM3.07 12.3l8.63 8.63C6.46 20.41 3 16.61 3 12c0-.23.01-.47.07-.7zm2.18 5.94L12 21.93c-.33.05-.67.07-1 .07-2.3 0-4.41-.82-6.05-2.16l.3-.6zm13.54-1.11C17.4 19.07 14.84 21 12 21c-.42 0-.83-.04-1.23-.1L4.1 14.23C3.4 13.55 3 12.8 3 12c0-1.56.95-2.9 2.32-3.48L12 15l6.79-6.79z"
                },
                {
                    title: "Web Applications",
                    desc: "Full-stack web apps built around your workflow — dashboards, portals, and tools designed for real-world use.",
                    accent: "#f97316",
                    icon: "M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm-5 14H4v-4h11v4zm0-5H4V9h11v4zm5 5h-4V9h4v9z"
                },
                {
                    title: "Python & Automation",
                    desc: "Scripts, automation pipelines, and data tools that eliminate repetitive work and connect your systems together.",
                    accent: "#ec4899",
                    icon: "M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"
                },
                {
                    title: "Geospatial",
                    desc: "Interactive maps and spatial analysis using ArcGIS, Leaflet, and QGIS — bringing location data to life on the web.",
                    accent: "#3b82f6",
                    icon: "M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
                },
                {
                    title: "Nonprofit & Scientific",
                    desc: "Specialized experience building tools and sites for nonprofit organizations and scientific teams with unique data and communication needs.",
                    accent: "#c084fc",
                    icon: "M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"
                },
            ].map(service => (
                    <div
                            class="service-card relative p-6 border border-neutral-800 rounded-xl transition-all duration-300 overflow-hidden"
                            style={`--accent: ${service.accent};`}
                    >
                        <!-- Top accent bar -->
                        <div class="absolute top-0 left-0 right-0 h-px"
                             style={`background: linear-gradient(90deg, transparent, ${service.accent}80, transparent);`}></div>

                        <!-- Hover glow -->
                        <div class="absolute inset-0 opacity-0 service-glow transition-opacity duration-300 rounded-xl"
                             style={`background: radial-gradient(ellipse at top left, ${service.accent}12 0%, transparent 60%);`}></div>

                        <!-- Icon -->
                        <div class="relative mb-4 w-8 h-8 rounded-lg flex items-center justify-center"
                             style={`background: ${service.accent}18;`}>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                 fill="currentColor" style={`color: ${service.accent};`}>
                                <path d={service.icon}/>
                            </svg>
                        </div>

                        <h3 class="relative text-white font-semibold mb-2">{service.title}</h3>
                        <p class="relative text-neutral-400 text-sm leading-relaxed">{service.desc}</p>
                    </div>
            ))}
        </div>
    </section>

    <style>
        .service-card:hover {
            border-color: color-mix(in srgb, var(--accent) 40%, transparent);
        }

        .service-card:hover .service-glow {
            opacity: 1;
        }
    </style>

    <!-- TOOLS & TECHNOLOGIES -->
    <section id="tools" class="py-24 px-6 max-w-4xl mx-auto border-t border-neutral-800">
        <p class="text-neutral-500 text-sm tracking-widest uppercase mb-4">Stack</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-12">Tools & Technologies.</h2>

        <!-- Top 8 grid -->
        <div class="grid grid-cols-4 gap-4 mb-6">
            {[
                {name: "Python", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/python/python-original.svg"},
                {
                    name: "JavaScript",
                    icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg"
                },
                {name: "WordPress", icon: "https://cdn.simpleicons.org/wordpress/ffffff"},
                {name: "Django", icon: "https://cdn.simpleicons.org/django/ffffff"},
                {name: "Vue.js", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/vuejs/vuejs-original.svg"},
                {
                    name: "PostgreSQL",
                    icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/postgresql/postgresql-original.svg"
                },
                {name: "ArcGIS", icon: "https://cdn.simpleicons.org/arcgis/ffffff"},
                {name: "Docker", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/docker/docker-original.svg"},
            ].map(tool => (
                    <div class="flex flex-col items-center gap-3 p-4 border border-neutral-800 rounded-xl hover:border-neutral-600 transition-colors group">
                        <div class="w-10 h-10 flex items-center justify-center">
                            <img src={tool.icon} alt={tool.name} class="w-full h-full object-contain"/>
                        </div>
                        <span class="text-neutral-400 text-xs text-center group-hover:text-white transition-colors">{tool.name}</span>
                    </div>
            ))}
        </div>

        <!-- Show more button -->
        <div class="flex justify-center mb-6">
            <button id="tools-toggle"
                    class="flex items-center gap-2 px-4 py-2 border border-neutral-700 text-neutral-400 rounded-lg hover:border-neutral-500 hover:text-white transition-colors text-sm">
                <span id="tools-toggle-label">Show more</span>
                <svg id="tools-toggle-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none"
                     viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
                     class="transition-transform duration-300">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
            </button>
        </div>

        <!-- Expanded section -->
        <div id="tools-expanded" class="overflow-hidden transition-all duration-500 ease-in-out"
             style="max-height: 0; opacity: 0;">
            <div class="grid grid-cols-4 gap-4 pb-4">
                {[
                    {name: "Angular", icon: "https://cdn.simpleicons.org/angular/ffffff"},
                    {name: "Astro", icon: "https://cdn.simpleicons.org/astro/ffffff"},
                    {name: "Bootstrap", icon: "https://cdn.simpleicons.org/bootstrap/ffffff"},
                    {
                        name: "Firebase",
                        icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/firebase/firebase-original.svg"
                    },
                    {name: "Git", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/git/git-original.svg"},
                    {
                        name: "HTML / CSS",
                        icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/html5/html5-original.svg"
                    },
                    {name: "Lando", icon: "/images/icons/lando.png"},
                    {name: "Leaflet", icon: "https://cdn.simpleicons.org/leaflet/ffffff"},
                    {name: "Linux", icon: "https://cdn.simpleicons.org/linux/ffffff"},
                    {name: "Netlify", icon: "https://cdn.simpleicons.org/netlify/ffffff"},
                    {name: "Node.js", icon: "https://cdn.simpleicons.org/nodedotjs/ffffff"},
                    {name: "PHP", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/php/php-original.svg"},
                    {name: "QGIS", icon: "https://cdn.simpleicons.org/qgis/ffffff"},
                    {
                        name: "React",
                        icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/react/react-original.svg"
                    },
                    {
                        name: "SQLite",
                        icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/sqlite/sqlite-original.svg"
                    },
                    {
                        name: "TypeScript",
                        icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg"
                    },
                    {
                        name: "Vagrant",
                        icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/vagrant/vagrant-original.svg"
                    },
                ].map(tool => (
                        <div class="flex flex-col items-center gap-3 p-4 border border-neutral-800 rounded-xl hover:border-neutral-600 transition-colors group">
                            <div class="w-10 h-10 flex items-center justify-center">
                                <img src={tool.icon} alt={tool.name} class="w-full h-full object-contain"/>
                            </div>
                            <span class="text-neutral-400 text-xs text-center group-hover:text-white transition-colors">{tool.name}</span>
                        </div>
                ))}
            </div>
        </div>
    </section>

    <script>
        const toggle = document.getElementById('tools-toggle')!;
        const expanded = document.getElementById('tools-expanded')!;
        const label = document.getElementById('tools-toggle-label')!;
        const icon = document.getElementById('tools-toggle-icon')!;
        let open = false;
        toggle.addEventListener('click', () => {
            open = !open;
            if (open) {
                expanded.style.maxHeight = expanded.scrollHeight + 'px';
                expanded.style.opacity = '1';
                label.textContent = 'Show less';
                icon.style.transform = 'rotate(180deg)';
            } else {
                expanded.style.maxHeight = '0';
                expanded.style.opacity = '0';
                label.textContent = 'Show more';
                icon.style.transform = 'rotate(0deg)';
            }
        });
    </script>

    <!-- PROJECTS -->
    <section id="projects" class="py-24 px-6 max-w-4xl mx-auto border-t border-neutral-800">
        <p class="text-neutral-500 text-sm tracking-widest uppercase mb-4">Projects</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-12">Recent work.</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="projects-grid">
            {[
                {
                    title: "Preserve Digital Archive",
                    desc: "A digital archive for Sawmill Slough Preserve — featuring custom GIS maps and applications cataloging over 1,200 species, 10,000 photos, and oral histories.",
                    tech: "WordPress · PHP · ArcGIS",
                    link: null,
                    images: [
                        "/images/projects/preserve/preserve-screenshot-1.png",
                        "/images/projects/preserve/preserve-screenshot-2.png",
                        "/images/projects/preserve/preserve-screenshot-3.png",
                    ]
                },
                {
                    title: "Coming Soon",
                    desc: "Project details coming soon.",
                    tech: "",
                    link: null,
                    images: []
                },
                {
                    title: "Coming Soon",
                    desc: "Project details coming soon.",
                    tech: "",
                    link: null,
                    images: []
                },
                {
                    title: "Coming Soon",
                    desc: "Project details coming soon.",
                    tech: "",
                    link: null,
                    images: []
                },
                {
                    title: "Coming Soon",
                    desc: "Project details coming soon.",
                    tech: "",
                    link: null,
                    images: []
                },
                {
                    title: "Coming Soon",
                    desc: "Project details coming soon.",
                    tech: "",
                    link: null,
                    images: []
                },
            ].map((project, pi) => (
                    <div class="border border-neutral-800 rounded-xl overflow-hidden hover:border-neutral-600 transition-colors group"
                         data-project={pi}>
                        <div class={`relative w-full h-48 bg-neutral-900 overflow-hidden ${project.images.length > 0 ? 'cursor-pointer gallery-container' : ''}`}
                             data-project={pi}>
                            {project.images.length > 0 ? (
                                    <>
                                        {project.images.map((img, ii) => (
                                                <img
                                                        src={img}
                                                        alt={`${project.title} screenshot ${ii + 1}`}
                                                        class={`gallery-img absolute inset-0 w-full h-full object-cover transition-opacity duration-300 ${ii === 0 ? 'opacity-100' : 'opacity-0'}`}
                                                        data-index={ii}
                                                        data-project={pi}
                                                />
                                        ))}
                                        {project.images.length > 1 && (
                                                <>
                                                    <button class="gallery-prev absolute left-2 top-1/2 -translate-y-1/2 z-10 w-7 h-7 rounded-full bg-black/60 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity hover:bg-black/80"
                                                            data-project={pi} aria-label="Previous">
                                                        <svg xmlns="http://www.w3.org/2000/svg"
                                                             width="14" height="14"
                                                             fill="none" viewBox="0 0 24 24"
                                                             stroke="currentColor"
                                                             stroke-width="2">
                                                            <path stroke-linecap="round"
                                                                  stroke-linejoin="round"
                                                                  d="M15 19l-7-7 7-7"/>
                                                        </svg>
                                                    </button>
                                                    <button class="gallery-next absolute right-2 top-1/2 -translate-y-1/2 z-10 w-7 h-7 rounded-full bg-black/60 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity hover:bg-black/80"
                                                            data-project={pi} aria-label="Next">
                                                        <svg xmlns="http://www.w3.org/2000/svg"
                                                             width="14" height="14"
                                                             fill="none" viewBox="0 0 24 24"
                                                             stroke="currentColor"
                                                             stroke-width="2">
                                                            <path stroke-linecap="round"
                                                                  stroke-linejoin="round"
                                                                  d="M9 5l7 7-7 7"/>
                                                        </svg>
                                                    </button>
                                                    <div class="absolute bottom-2 left-1/2 -translate-x-1/2 flex gap-1 z-10">
                                                        {project.images.map((_, di) => (
                                                                <button class={`gallery-dot w-1.5 h-1.5 rounded-full transition-colors ${di === 0 ? 'bg-white' : 'bg-white/40'}`}
                                                                        data-project={pi}
                                                                        data-index={di}
                                                                        aria-label={`Go to screenshot ${di + 1}`}></button>
                                                        ))}
                                                    </div>
                                                </>
                                        )}
                                        <div class="absolute top-2 right-2 z-10 opacity-0 group-hover:opacity-100 transition-opacity">
                                            <div class="bg-black/60 rounded px-2 py-1 text-xs text-white/70">
                                                click to
                                                expand
                                            </div>
                                        </div>
                                    </>
                            ) : (
                                    <div class="absolute inset-0 flex items-center justify-center text-neutral-700 text-sm">
                                        No preview available
                                    </div>
                            )}
                        </div>
                        <div class="p-5">
                            <div class="flex items-start justify-between gap-2 mb-2">
                                <h3 class="text-white font-semibold">{project.title}</h3>
                                {project.link && (
                                        <a href={project.link} target="_blank" rel="noopener noreferrer"
                                           class="text-xs text-neutral-400 border border-neutral-700 rounded px-2 py-1 hover:text-white hover:border-neutral-500 transition-colors whitespace-nowrap">
                                            Live site ↗
                                        </a>
                                )}
                            </div>
                            <p class="text-neutral-400 text-sm mb-3 leading-relaxed">{project.desc}</p>
                            {project.tech &&
                                    <span class="text-xs text-neutral-600">{project.tech}</span>}
                        </div>
                    </div>
            ))}
        </div>
    </section>

    <!-- LIGHTBOX -->
    <div id="lightbox" class="fixed inset-0 z-50 bg-black/90 hidden items-center justify-center"
         role="dialog"
         aria-modal="true">
        <button id="lightbox-close"
                class="absolute top-4 right-4 text-white/70 hover:text-white transition-colors z-10"
                aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none"
                 viewBox="0 0 24 24"
                 stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
        </button>
        <button id="lightbox-prev"
                class="absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/10 text-white flex items-center justify-center hover:bg-white/20 transition-colors"
                aria-label="Previous">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none"
                 viewBox="0 0 24 24"
                 stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
            </svg>
        </button>
        <button id="lightbox-next"
                class="absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/10 text-white flex items-center justify-center hover:bg-white/20 transition-colors"
                aria-label="Next">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none"
                 viewBox="0 0 24 24"
                 stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
        </button>
        <div class="flex flex-col items-center gap-4 max-w-5xl w-full px-16">
            <img id="lightbox-img" src="" alt=""
                 class="max-h-[75vh] w-auto rounded-lg shadow-2xl object-contain"/>
            <div class="flex flex-col items-center gap-2">
                <p id="lightbox-title" class="text-white font-semibold text-lg"></p>
                <div id="lightbox-dots" class="flex gap-2"></div>
            </div>
        </div>
    </div>

    <script>
        const projects = [
            {
                title: "Preserve Digital Archive",
                images: [
                    "/images/projects/preserve/preserve-screenshot-1.png",
                    "/images/projects/preserve/preserve-screenshot-2.png",
                    "/images/projects/preserve/preserve-screenshot-3.png",
                ]
            },
            {title: "Coming Soon", images: []},
            {title: "Coming Soon", images: []},
            {title: "Coming Soon", images: []},
            {title: "Coming Soon", images: []},
            {title: "Coming Soon", images: []},
        ];

        const currentIndex: Record<number, number> = {};
        projects.forEach((_, i) => currentIndex[i] = 0);

        function setCardImage(pi: number, idx: number) {
            const imgs = document.querySelectorAll<HTMLImageElement>(`.gallery-img[data-project="${pi}"]`);
            const dots = document.querySelectorAll<HTMLButtonElement>(`.gallery-dot[data-project="${pi}"]`);
            imgs.forEach((img, i) => img.classList.toggle('opacity-100', i === idx));
            imgs.forEach((img, i) => img.classList.toggle('opacity-0', i !== idx));
            dots.forEach((dot, i) => {
                dot.classList.toggle('bg-white', i === idx);
                dot.classList.toggle('bg-white/40', i !== idx);
            });
            currentIndex[pi] = idx;
        }

        document.querySelectorAll('.gallery-prev').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                const pi = parseInt((btn as HTMLElement).dataset.project!);
                const total = projects[pi].images.length;
                setCardImage(pi, (currentIndex[pi] - 1 + total) % total);
            });
        });

        document.querySelectorAll('.gallery-next').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                const pi = parseInt((btn as HTMLElement).dataset.project!);
                const total = projects[pi].images.length;
                setCardImage(pi, (currentIndex[pi] + 1) % total);
            });
        });

        document.querySelectorAll('.gallery-dot').forEach(dot => {
            dot.addEventListener('click', (e) => {
                e.stopPropagation();
                const el = dot as HTMLElement;
                const pi = parseInt(el.dataset.project!);
                const idx = parseInt(el.dataset.index!);
                setCardImage(pi, idx);
            });
        });

        const lightbox = document.getElementById('lightbox')!;
        const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
        const lightboxTitle = document.getElementById('lightbox-title')!;
        const lightboxDots = document.getElementById('lightbox-dots')!;
        let lbProject = 0;
        let lbIndex = 0;

        function openLightbox(pi: number, idx: number) {
            lbProject = pi;
            lbIndex = idx;
            updateLightbox();
            lightbox.classList.remove('hidden');
            lightbox.classList.add('flex');
            document.body.style.overflow = 'hidden';
        }

        function closeLightbox() {
            lightbox.classList.add('hidden');
            lightbox.classList.remove('flex');
            document.body.style.overflow = '';
        }

        function updateLightbox() {
            const p = projects[lbProject];
            lightboxImg.src = p.images[lbIndex];
            lightboxImg.alt = `${p.title} screenshot ${lbIndex + 1}`;
            lightboxTitle.textContent = p.title;
            lightboxDots.innerHTML = '';
            p.images.forEach((_, i) => {
                const dot = document.createElement('button');
                dot.className = `w-2 h-2 rounded-full transition-colors ${i === lbIndex ? 'bg-white' : 'bg-white/30'}`;
                dot.addEventListener('click', () => {
                    lbIndex = i;
                    updateLightbox();
                });
                lightboxDots.appendChild(dot);
            });
            const single = p.images.length <= 1;
            (document.getElementById('lightbox-prev') as HTMLElement).style.display = single ? 'none' : '';
            (document.getElementById('lightbox-next') as HTMLElement).style.display = single ? 'none' : '';
        }

        document.querySelectorAll('.gallery-container').forEach(container => {
            container.addEventListener('click', () => {
                const pi = parseInt((container as HTMLElement).dataset.project!);
                if (projects[pi].images.length > 0) openLightbox(pi, currentIndex[pi]);
            });
        });

        document.getElementById('lightbox-close')!.addEventListener('click', closeLightbox);

        document.getElementById('lightbox-prev')!.addEventListener('click', () => {
            const total = projects[lbProject].images.length;
            lbIndex = (lbIndex - 1 + total) % total;
            updateLightbox();
        });

        document.getElementById('lightbox-next')!.addEventListener('click', () => {
            const total = projects[lbProject].images.length;
            lbIndex = (lbIndex + 1) % total;
            updateLightbox();
        });

        lightbox.addEventListener('click', (e) => {
            if (e.target === lightbox) closeLightbox();
        });

        document.addEventListener('keydown', (e) => {
            if (!lightbox.classList.contains('flex')) return;
            if (e.key === 'Escape') closeLightbox();
            if (e.key === 'ArrowLeft') {
                const total = projects[lbProject].images.length;
                lbIndex = (lbIndex - 1 + total) % total;
                updateLightbox();
            }
            if (e.key === 'ArrowRight') {
                const total = projects[lbProject].images.length;
                lbIndex = (lbIndex + 1) % total;
                updateLightbox();
            }
        });
    </script>

    <!-- CONTACT -->
    <section id="contact" class="py-24 px-6 max-w-2xl mx-auto border-t border-neutral-800">
        <p class="text-neutral-500 text-sm tracking-widest uppercase mb-4">Contact</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Let's work together.</h2>
        <p class="text-neutral-400 mb-10">Have a project in mind? Fill out the form below and I'll get
            back to you
            within 24 hours.</p>
        <form name="contact" netlify-honeypot="bot-field" netlify class="flex flex-col gap-4">
            <input type="hidden" name="form-name" value="contact"/>
            <p class="hidden" aria-hidden="true">
                <input name="bot-field" autocomplete="off"/>
            </p>
            <input type="text" name="name" placeholder="Your name"
                   class="bg-neutral-900 border border-neutral-800 rounded-lg px-4 py-3 text-white placeholder-neutral-600 focus:outline-none focus:border-neutral-500 transition-colors"/>
            <input type="email" name="email" placeholder="Your email"
                   class="bg-neutral-900 border border-neutral-800 rounded-lg px-4 py-3 text-white placeholder-neutral-600 focus:outline-none focus:border-neutral-500 transition-colors"/>
            <textarea name="message" placeholder="Tell me about your project" rows="5"
                      class="bg-neutral-900 border border-neutral-800 rounded-lg px-4 py-3 text-white placeholder-neutral-600 focus:outline-none focus:border-neutral-500 transition-colors resize-none"></textarea>
            <button type="submit"
                    class="px-6 py-3 bg-white text-neutral-950 font-medium rounded-lg hover:bg-neutral-200 transition-colors text-sm w-fit">
                Send message
            </button>
        </form>
    </section>

    <!-- FOOTER -->
    <footer class="py-8 px-6 border-t border-neutral-800 text-center text-neutral-600 text-sm">
        © {new Date().getFullYear()} James W. Taylor · jamestaylor.dev
    </footer>
</Base>